    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "navbar": {
    "links": [
      {
        "label": "Sign In",
        "href": "https://app.certgovernance.app/login"
      }
